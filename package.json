{
  "name": "ecosystem-tooling",
  "version": "0.0.0",
  "private": true,
  "description": "Aztec ecosystem packages — bun monorepo continuing Wonderland's aztec-fee-payment and aztec-benchmark",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alejoamiras/ecosystem-tooling.git"
  },
  "license": "MIT",
  "author": "Alejo Amiras",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bench": "bun run --cwd packages/private-fee-juice benchmark",
    "codegen": "bun run --filter '*' codegen",
    "compile": "bun run --filter '*' compile",
    "lint": "biome check . && sort-package-json --check \"package.json\" \"packages/*/package.json\"",
    "lint:actions": "actionlint",
    "lint:fix": "biome check --write . && sort-package-json \"package.json\" \"packages/*/package.json\"",
    "lint:shell": "shellcheck scripts/*.sh",
    "prepare": "husky",
    "test": "bun run test:nr && bun run test:js",
    "test:js": "bun run --cwd packages/private-fee-juice test:js",
    "test:nr": "bun run --cwd packages/private-fee-juice test:nr",
    "typecheck": "bun run --cwd packages/private-fee-juice typecheck && bun run --cwd packages/aztec-benchmark typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.nr": [
      "bash scripts/fmt-nr-staged.sh"
    ],
    "*.sh": [
      "shellcheck"
    ],
    ".github/workflows/*.yml": [
      "actionlint"
    ],
    "**/package.json": [
      "sort-package-json"
    ]
  },
  "config": {
    "aztecVersion": "5.0.1"
  },
  "overrides": {
    "@noble/hashes": "1.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "sort-package-json": "^4.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
