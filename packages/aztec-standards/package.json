{
  "name": "@alejoamiras/aztec-standards",
  "version": "5.0.0",
  "description": "Reusable, standardized contracts for the Aztec Network (token, vault, NFT, escrow, dripper, proxy)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alejoamiras/ecosystem-tooling.git",
    "directory": "packages/aztec-standards"
  },
  "license": "MIT",
  "author": "Wonderland",
  "type": "module",
  "exports": {
    "./artifacts/*": "./artifacts/*",
    "./target/*": "./target/*",
    "./deployments.json": "./deployments.json",
    "./package.json": "./package.json"
  },
  "files": [
    "artifacts",
    "target",
    "deployments.json",
    "README.md",
    "LICENSE",
    "!target/*.json.bak"
  ],
  "scripts": {
    "bench": "NODE_NO_WARNINGS=1 aztec-benchmark --suffix _base",
    "build": "bash scripts/build.sh",
    "ccc": "bun run clean && bun run compile && bun run codegen",
    "clean": "rm -rf ./src/artifacts ./target ./artifacts ./dist ./deployments.json codegenCache.json",
    "codegen": "aztec codegen target --outdir src/artifacts -f",
    "compile": "aztec compile",
    "deploy": "NODE_NO_WARNINGS=1 tsx scripts/deploy.ts",
    "test": "bun run test:nr && bun run test:js",
    "test:js": "vitest run",
    "test:nr": "aztec test",
    "typecheck": "tsc --noEmit -p tsconfig.check.json"
  },
  "devDependencies": {
    "@alejoamiras/aztec-benchmark": "5.0.0",
    "@aztec/accounts": "5.0.0",
    "@aztec/aztec.js": "5.0.0",
    "@aztec/bb.js": "5.0.0",
    "@aztec/constants": "5.0.0",
    "@aztec/foundation": "5.0.0",
    "@aztec/noir-contracts.js": "5.0.0",
    "@aztec/protocol-contracts": "5.0.0",
    "@aztec/pxe": "5.0.0",
    "@aztec/stdlib": "5.0.0",
    "@aztec/wallet-sdk": "5.0.0",
    "@aztec/wallets": "5.0.0",
    "@noble/hashes": "1.8.0",
    "@types/node": "25.0.10",
    "commander": "14.0.1",
    "dotenv": "16.4.7",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "viem": "npm:@aztec/viem@2.38.2",
    "vitest": "4.0.17"
  },
  "peerDependencies": {
    "@aztec/accounts": "5.0.0",
    "@aztec/aztec.js": "5.0.0",
    "@aztec/noir-contracts.js": "5.0.0",
    "@aztec/protocol-contracts": "5.0.0",
    "@aztec/pxe": "5.0.0",
    "@aztec/stdlib": "5.0.0",
    "@aztec/wallet-sdk": "5.0.0",
    "@aztec/wallets": "5.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
