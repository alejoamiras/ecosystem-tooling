{
  "name": "@alejoamiras/aztec-benchmark",
  "version": "5.0.0",
  "description": "CLI tool and GitHub Action for Aztec contract benchmarking",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alejoamiras/ecosystem-tooling.git",
    "directory": "packages/aztec-benchmark"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aztec-benchmark": "bin/aztec-benchmark"
  },
  "files": [
    "dist",
    "action",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && ncc build action/index.cjs -o action/dist -m -C",
    "start": "tsx cli/cli.ts",
    "typecheck": "tsc --noEmit -p tsconfig.check.json"
  },
  "dependencies": {
    "@actions/core": "1.10.1",
    "@actions/exec": "1.1.1",
    "@iarna/toml": "2.2.5",
    "commander": "13.1.0",
    "esbuild": "0.25.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
  },
  "devDependencies": {
    "@aztec/aztec.js": "5.0.0",
    "@aztec/stdlib": "5.0.0",
    "@aztec/wallets": "5.0.0",
    "@types/node": "22.15.3",
    "@vercel/ncc": "0.38.3"
  },
  "peerDependencies": {
    "@aztec/aztec.js": "5.0.0",
    "@aztec/wallets": "5.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
