{
  "name": "@alejoamiras/aztec-fee-payment",
  "version": "5.0.1",
  "description": "Private Fee Payment Contract (FPC) for Aztec — Noir contract + TypeScript SDK",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alejoamiras/ecosystem-tooling.git",
    "directory": "packages/aztec-fee-payment"
  },
  "license": "MIT",
  "author": "Wonderland",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/ts/index.js",
      "types": "./dist/src/ts/index.d.ts"
    },
    "./artifacts/private": {
      "import": "./dist/src/artifacts/PrivateFPC.js",
      "types": "./dist/src/artifacts/PrivateFPC.d.ts"
    },
    "./fee-payment-methods": {
      "import": "./dist/src/ts/fee-payment-methods/index.js",
      "types": "./dist/src/ts/fee-payment-methods/index.d.ts"
    },
    "./utils": {
      "import": "./dist/src/ts/utils/index.js",
      "types": "./dist/src/ts/utils/index.d.ts"
    },
    "./canonical-deployment.json": "./canonical-deployment.json",
    "./package.json": "./package.json"
  },
  "main": "./dist/src/ts/index.js",
  "types": "./dist/src/ts/index.d.ts",
  "files": [
    "dist",
    "target",
    "!target/*.json.bak",
    "canonical-deployment.json"
  ],
  "scripts": {
    "benchmark": "aztec-benchmark --suffix _base",
    "build": "bun run compile && bun run codegen && bunx tsc --project tsconfig.build.json",
    "ccc": "bun run clean && bun run compile && bun run codegen",
    "clean": "rm -rf ./src/artifacts/* ./target ./dist codegenCache.json",
    "codegen": "aztec codegen target --outdir src/artifacts -f",
    "compile": "aztec compile",
    "compute": "NODE_NO_WARNINGS=1 tsx scripts/compute.ts",
    "test": "bun run test:nr && bun run test:js",
    "test:js": "vitest run",
    "test:nr": "aztec test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "upload:artifacts": "tsx scripts/upload-artifact.ts"
  },
  "devDependencies": {
    "@alejoamiras/aztec-benchmark": "5.0.1",
    "@aztec/accounts": "5.0.1",
    "@aztec/aztec.js": "5.0.1",
    "@aztec/bb.js": "5.0.1",
    "@aztec/constants": "5.0.1",
    "@aztec/entrypoints": "5.0.1",
    "@aztec/ethereum": "5.0.1",
    "@aztec/foundation": "5.0.1",
    "@aztec/l1-artifacts": "5.0.1",
    "@aztec/noir-contracts.js": "5.0.1",
    "@aztec/protocol-contracts": "5.0.1",
    "@aztec/pxe": "5.0.1",
    "@aztec/stdlib": "5.0.1",
    "@aztec/wallets": "5.0.1",
    "@noble/hashes": "1.8.0",
    "@types/node": "25.6.0",
    "dotenv": "17.4.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "viem": "npm:@aztec/viem@2.38.2",
    "vitest": "4.1.4",
    "zod": "^4.4.0"
  },
  "peerDependencies": {
    "@aztec/aztec.js": "5.0.1",
    "@aztec/protocol-contracts": "5.0.1",
    "@aztec/stdlib": "5.0.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
