# PrivateFPC Configuration
# Copy this file to .env and fill in your values

# Required: Salt used to derive the PrivateFPC contract address
# The address is deterministic from the class hash + salt
PRIVATE_FPC_SALT=

# L1 Configuration (required for bridging Fee Juice to the FPC)
# Private key for L1 account (Sepolia)
# L1_PRIVATE_KEY=0x...

# Alternative: L1 mnemonic (if not using private key)
# L1_MNEMONIC=your mnemonic phrase here

# Optional: Override L1 RPC URL (defaults to public Sepolia RPC)
# L1_RPC_URL=https://rpc.sepolia.ethpandaops.io
